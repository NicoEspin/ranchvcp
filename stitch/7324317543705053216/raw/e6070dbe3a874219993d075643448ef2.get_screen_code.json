{"screenId":"e6070dbe3a874219993d075643448ef2","projectId":"7324317543705053216","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"es\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Ranch VCP | Carta Digital</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            \"colors\": {\n                    \"tertiary\": \"#e0ffdf\",\n                    \"on-primary-fixed\": \"#261a00\",\n                    \"secondary-fixed\": \"#ffdf9f\",\n                    \"surface\": \"#131313\",\n                    \"on-primary-fixed-variant\": \"#5c4300\",\n                    \"on-error\": \"#690005\",\n                    \"secondary\": \"#f0c052\",\n                    \"surface-card\": \"#151515\",\n                    \"border-warm\": \"#1B130F\",\n                    \"on-error-container\": \"#ffdad6\",\n                    \"surface-container-low\": \"#1c1b1b\",\n                    \"inverse-surface\": \"#e5e2e1\",\n                    \"tertiary-fixed-dim\": \"#3de273\",\n                    \"surface-bright\": \"#3a3939\",\n                    \"on-secondary-container\": \"#372700\",\n                    \"on-secondary\": \"#402d00\",\n                    \"surface-dim\": \"#131313\",\n                    \"surface-input\": \"#120D0A\",\n                    \"background\": \"#090909\",\n                    \"whatsapp-green\": \"#25D366\",\n                    \"surface-container-lowest\": \"#0e0e0e\",\n                    \"error\": \"#ffb4ab\",\n                    \"outline\": \"#9a8f7f\",\n                    \"on-tertiary-container\": \"#006f30\",\n                    \"on-background\": \"#e5e2e1\",\n                    \"secondary-fixed-dim\": \"#f0c052\",\n                    \"surface-tint\": \"#e9c16c\",\n                    \"tertiary-container\": \"#57f785\",\n                    \"surface-variant\": \"#353534\",\n                    \"surface-container-highest\": \"#353534\",\n                    \"on-surface-variant\": \"#d1c5b3\",\n                    \"on-secondary-fixed-variant\": \"#5c4300\",\n                    \"outline-variant\": \"#4e4638\",\n                    \"on-tertiary-fixed\": \"#002109\",\n                    \"text-muted\": \"#d2c5b0\",\n                    \"on-primary-container\": \"#795b0d\",\n                    \"error-container\": \"#93000a\",\n                    \"primary\": \"#fff6ea\",\n                    \"gold\": \"#E8B84B\",\n                    \"primary-fixed-dim\": \"#e9c16c\",\n                    \"surface-container\": \"#201f1f\",\n                    \"secondary-container\": \"#b58a1f\",\n                    \"inverse-on-surface\": \"#313030\",\n                    \"on-surface\": \"#e5e2e1\",\n                    \"inverse-primary\": \"#785a0c\",\n                    \"primary-container\": \"#ffd57e\",\n                    \"surface-container-high\": \"#2a2a2a\",\n                    \"on-secondary-fixed\": \"#261a00\",\n                    \"on-primary\": \"#402d00\",\n                    \"primary-fixed\": \"#ffdf9f\",\n                    \"on-tertiary-fixed-variant\": \"#005322\",\n                    \"tertiary-fixed\": \"#66ff8e\",\n                    \"on-tertiary\": \"#003915\"\n            },\n            \"borderRadius\": {\n                    \"DEFAULT\": \"0.125rem\",\n                    \"lg\": \"0.25rem\",\n                    \"xl\": \"0.5rem\",\n                    \"full\": \"0.75rem\"\n            },\n            \"spacing\": {\n                    \"container-max\": \"1280px\",\n                    \"sm\": \"12px\",\n                    \"lg\": \"48px\",\n                    \"xl\": \"80px\",\n                    \"base\": \"8px\",\n                    \"xs\": \"4px\",\n                    \"md\": \"24px\",\n                    \"gutter\": \"24px\"\n            },\n            \"fontFamily\": {\n                    \"display-lg\": [\"Bebas Neue\"],\n                    \"headline-lg\": [\"Bebas Neue\"],\n                    \"headline-md\": [\"Bebas Neue\"],\n                    \"label-md\": [\"DM Sans\"],\n                    \"body-md\": [\"DM Sans\"],\n                    \"body-lg\": [\"DM Sans\"],\n                    \"title-lg\": [\"DM Sans\"],\n                    \"caption\": [\"DM Sans\"]\n            },\n            \"fontSize\": {\n                    \"label-md\": [\"14px\", {\"lineHeight\": \"20px\", \"letterSpacing\": \"0.05em\", \"fontWeight\": \"500\"}],\n                    \"headline-lg\": [\"40px\", {\"lineHeight\": \"44px\", \"letterSpacing\": \"0.03em\", \"fontWeight\": \"400\"}],\n                    \"headline-md\": [\"32px\", {\"lineHeight\": \"36px\", \"letterSpacing\": \"0.03em\", \"fontWeight\": \"400\"}],\n                    \"body-md\": [\"16px\", {\"lineHeight\": \"24px\", \"fontWeight\": \"400\"}],\n                    \"body-lg\": [\"18px\", {\"lineHeight\": \"28px\", \"fontWeight\": \"400\"}],\n                    \"title-lg\": [\"20px\", {\"lineHeight\": \"28px\", \"fontWeight\": \"700\"}],\n                    \"display-lg\": [\"80px\", {\"lineHeight\": \"80px\", \"letterSpacing\": \"0.02em\", \"fontWeight\": \"400\"}],\n                    \"caption\": [\"12px\", {\"lineHeight\": \"16px\", \"fontWeight\": \"400\"}]\n            }\n          },\n        },\n      }\n    </script>\n<style>\n        body {\n            background-color: #090909;\n            color: #e5e2e1;\n            scroll-behavior: smooth;\n        }\n        .glass-nav {\n            background: rgba(19, 19, 19, 0.8);\n            backdrop-filter: blur(20px);\n        }\n        .gold-glow {\n            box-shadow: 0 0 20px rgba(232, 184, 75, 0.2);\n        }\n        .gold-glow-text {\n            text-shadow: 0 0 10px rgba(232, 184, 75, 0.4);\n        }\n        .no-scrollbar::-webkit-scrollbar {\n            display: none;\n        }\n        .no-scrollbar {\n            -ms-overflow-style: none;\n            scrollbar-width: none;\n        }\n        .card-hover:hover {\n            transform: translateY(-4px);\n            border-color: #E8B84B;\n        }\n    </style>\n</head>\n<body class=\"font-body-md overflow-x-hidden\">\n<!-- Header Section -->\n<header class=\"fixed top-0 left-0 w-full z-50 glass-nav border-b border-outline-variant/30 px-lg py-md flex justify-between items-center max-w-container-max mx-auto left-1/2 -translate-x-1/2\">\n<div class=\"flex items-center gap-xl\">\n<h1 class=\"font-headline-lg text-headline-lg text-primary tracking-tighter\">Ranch VCP</h1>\n<nav class=\"hidden md:flex gap-md\">\n<a class=\"font-label-md text-label-md uppercase tracking-widest text-on-surface-variant hover:text-on-surface transition-colors\" href=\"#\">Inicio</a>\n<a class=\"font-label-md text-label-md uppercase tracking-widest text-primary border-b-2 border-primary pb-1\" href=\"#\">Men├║</a>\n<a class=\"font-label-md text-label-md uppercase tracking-widest text-on-surface-variant hover:text-on-surface transition-colors\" href=\"#\">Reservas</a>\n</nav>\n</div>\n<div class=\"flex items-center gap-md\">\n<button class=\"relative flex items-center gap-xs px-md py-sm bg-surface-container-high rounded transition-all active:scale-95 group\">\n<span class=\"material-symbols-outlined text-gold\">shopping_cart</span>\n<span class=\"font-label-md text-label-md uppercase tracking-widest text-on-surface group-hover:text-gold transition-colors\">Ver pedido</span>\n<span class=\"absolute -top-1 -right-1 bg-gold text-on-primary-fixed w-5 h-5 flex items-center justify-center text-[10px] font-bold rounded-full\">3</span>\n</button>\n<button class=\"bg-whatsapp-green text-on-tertiary-fixed font-label-md text-label-md uppercase tracking-widest px-md py-sm rounded-lg flex items-center gap-xs hover:opacity-90 transition-opacity active:scale-95\">\n<span class=\"material-symbols-outlined text-[20px]\">chat</span>\n                Pedir ahora\n            </button>\n</div>\n</header>\n<main class=\"mt-[100px] max-w-container-max mx-auto px-lg\">\n<!-- Hero Compacto -->\n<section class=\"grid grid-cols-1 md:grid-cols-2 gap-lg items-center py-xl\">\n<div class=\"space-y-md\">\n<span class=\"font-label-md text-label-md uppercase tracking-[0.3em] text-gold gold-glow-text\">Gastronom├¡a Industrial</span>\n<h2 class=\"font-display-lg text-display-lg leading-tight italic uppercase text-primary\">Arm├í tu pedido<br/><span class=\"text-gold\">Ranch</span></h2>\n<p class=\"font-body-lg text-body-lg text-on-surface-variant max-w-[480px]\">Comida fuerte para noches con hambre. Eleg├¡ tus favoritos y te los llevamos volando.</p>\n</div>\n<div class=\"relative h-[400px] rounded-xl overflow-hidden group\">\n<img class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" data-alt=\"A macro close-up of a juicy premium cheeseburger with melted cheddar cheese dripping down the side. The burger is placed on a dark wooden board with tendrils of steam rising around it against a pitch-black background. High-contrast amber lighting highlights the textures of the brioche bun and the seared meat, creating a cinematic and high-energy food aesthetic.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDUJppTdYqnSLM3JHIVOafUaCbmh8umnERz5XWNCIkR2EuEEFAgMi6kEXpqcSGK3tWXYjrRCQ18lz5BzLICVXGudhJTQRvz5d-CJP-iQKh5qo56sDHV_yXQhA9vKqFCjsWQO8wYzfQpAfUHXNS_GhFiV2BCdXuJC3uE-mk9CgLzJ-9dtFc-_oItC4TLU0x04nH3CZ3ADYkJYbqE4MyfoSnvF4bXttl79GOKp4RKpeUb_YghuDXgiNXqMzdjPyWjCafJtIOOv3qnoPU\"/>\n<div class=\"absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent\"></div>\n</div>\n</section>\n<!-- Selector de Sucursal -->\n<section class=\"pb-xl\">\n<div class=\"flex flex-col gap-sm\">\n<p class=\"font-label-md text-label-md uppercase tracking-widest text-on-surface-variant\">Seleccion├í tu sucursal</p>\n<div class=\"flex gap-md\">\n<button class=\"flex-1 max-w-[200px] bg-surface-card border-2 border-gold p-md rounded-xl flex items-center gap-md group gold-glow\">\n<div class=\"w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-gold\">location_on</span>\n</div>\n<div class=\"text-left\">\n<p class=\"font-title-lg text-title-lg text-primary\">Uruguay</p>\n<p class=\"font-caption text-caption text-gold uppercase tracking-tighter\">Seleccionado</p>\n</div>\n</button>\n<button class=\"flex-1 max-w-[200px] bg-surface-card border border-border-warm p-md rounded-xl flex items-center gap-md hover:border-outline-variant transition-colors group\">\n<div class=\"w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center group-hover:bg-gold/10 transition-colors\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-gold transition-colors\">location_on</span>\n</div>\n<div class=\"text-left\">\n<p class=\"font-title-lg text-title-lg text-on-surface-variant group-hover:text-primary transition-colors\">Libertad</p>\n<p class=\"font-caption text-caption text-on-surface-variant\">C├│rdoba, AR</p>\n</div>\n</button>\n</div>\n</div>\n</section>\n<!-- Barra de Categor├¡as Sticky -->\n<div class=\"sticky top-[88px] z-40 bg-background/95 backdrop-blur-md -mx-lg px-lg py-md border-b border-border-warm mb-xl overflow-x-auto no-scrollbar\">\n<div class=\"flex gap-xl min-w-max\">\n<a class=\"font-headline-md text-headline-md uppercase text-gold border-b-2 border-gold pb-1 tracking-wider\" href=\"#burgers\">Burgers</a>\n<a class=\"font-headline-md text-headline-md uppercase text-on-surface-variant hover:text-primary transition-colors tracking-wider\" href=\"#pizzas\">Pizzas</a>\n<a class=\"font-headline-md text-headline-md uppercase text-on-surface-variant hover:text-primary transition-colors tracking-wider\" href=\"#lomos\">Lomos</a>\n<a class=\"font-headline-md text-headline-md uppercase text-on-surface-variant hover:text-primary transition-colors tracking-wider\" href=\"#empanadas\">Empanadas</a>\n<a class=\"font-headline-md text-headline-md uppercase text-on-surface-variant hover:text-primary transition-colors tracking-wider\" href=\"#pastas\">Pastas</a>\n<a class=\"font-headline-md text-headline-md uppercase text-on-surface-variant hover:text-primary transition-colors tracking-wider\" href=\"#bebidas\">Bebidas</a>\n</div>\n</div>\n<!-- Cuerpo Principal -->\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-xl pb-xl\">\n<!-- Listado de Productos -->\n<div class=\"lg:col-span-8 space-y-xl\">\n<!-- Category: Burgers -->\n<div class=\"space-y-md\" id=\"burgers\">\n<h3 class=\"font-headline-lg text-headline-lg text-primary italic uppercase flex items-center gap-md\">\n<span class=\"w-8 h-[2px] bg-gold\"></span> Burgers\n                    </h3>\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-gutter\">\n<!-- Product Card 1 -->\n<div class=\"bg-surface-card border border-border-warm rounded-xl overflow-hidden card-hover transition-all flex flex-col group\">\n<div class=\"h-48 overflow-hidden\">\n<img class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-105\" data-alt=\"A gourmet cheeseburger with multiple layers of flame-grilled beef patties, melting yellow cheese, and fresh greens. The image is shot in a dark, moody environment with dramatic warm key lighting highlighting the glistening oils and meat textures. Deep black background with a subtle wooden surface below, perfectly matching the RANCH VCP industrial gastro aesthetic.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCi9h1t5gKTA8EtuQ-Ji2rQxVyBSFGjp2yulHytxsuG7Nm6fIo79kIU2hk9-p1tilTelxY1UPVGJMrs-u_jX7EGHewxS6VzWIW5-v04uYy9PYyEvR7uo60j3ymaZrnWT5h35e7obqkF-8ECv3soQRkkqzQ0LpWO6Hpj051Z9lSE4Wxi0poA_XvyH3pa7lFC26_C3mCksARX0NfqxovDqizrZi5Y0eujIWsbbLsP-Oj03JBYUOjo8ySERAfwFuBa37EuLF7aF_gZ3Bw\"/>\n</div>\n<div class=\"p-md flex flex-col flex-1 gap-sm\">\n<div class=\"flex justify-between items-start\">\n<h4 class=\"font-title-lg text-title-lg text-primary\">Ranch Burger</h4>\n<span class=\"font-headline-md text-headline-md text-gold\">$8.900</span>\n</div>\n<p class=\"font-body-md text-body-md text-on-surface-variant flex-1 line-clamp-2\">Doble medall├│n de carne, cheddar, cebolla caramelizada y salsa secreta Ranch.</p>\n<button class=\"mt-base w-full bg-primary-container text-on-primary-fixed font-label-md text-label-md uppercase tracking-widest py-sm rounded-lg flex items-center justify-center gap-sm active:scale-95 transition-transform hover:opacity-90 gold-glow\">\n<span class=\"material-symbols-outlined text-[20px]\">add_circle</span>\n                                    Agregar\n                                </button>\n</div>\n</div>\n<!-- Product Card 2 -->\n<div class=\"bg-surface-card border border-border-warm rounded-xl overflow-hidden card-hover transition-all flex flex-col group\">\n<div class=\"h-48 overflow-hidden\">\n<img class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-105\" data-alt=\"A smoky, flame-grilled burger with thick bacon strips and melted cheese under a warm amber glow. The food is presented elegantly on a dark rustic surface against a deep black backdrop. Subtle golden highlights on the rim of the burger capture the essence of high-end late-night dining and aggressive, bold flavors.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAqzcgWY26LoxB7z3nXLoLVHSCEA4Ny2vC5RXIivPYIkiTWG_iodtPu7Q_DCxJMl8L_Oa7FUzyrMlaSmzffoprCoB7x0dvgt-PoYWWuevBq5qJmLXqqD2_RmYRNHDlyYyND6xEBv5GDjyWAHCFJerwkLiiH0jV_nQx4mR7O7RcDvLnoU17d-z-HiKbDvINnL51WErAn6DAoXGUTErrzIDz3-wwOLLOmvRtC_Qh1VjgwQrQPIa9TMYQp_TWJnPf-4KSUzN9-LRK811I\"/>\n</div>\n<div class=\"p-md flex flex-col flex-1 gap-sm\">\n<div class=\"flex justify-between items-start\">\n<h4 class=\"font-title-lg text-title-lg text-primary\">Smoky Burger</h4>\n<span class=\"font-headline-md text-headline-md text-gold\">$9.400</span>\n</div>\n<p class=\"font-body-md text-body-md text-on-surface-variant flex-1 line-clamp-2\">Medall├│n de 180g, panceta ahumada, alioli y provolone fundido.</p>\n<button class=\"mt-base w-full bg-primary-container text-on-primary-fixed font-label-md text-label-md uppercase tracking-widest py-sm rounded-lg flex items-center justify-center gap-sm active:scale-95 transition-transform hover:opacity-90 gold-glow\">\n<span class=\"material-symbols-outlined text-[20px]\">add_circle</span>\n                                    Agregar\n                                </button>\n</div>\n</div>\n</div>\n</div>\n<!-- Category: Pizzas -->\n<div class=\"space-y-md\" id=\"pizzas\">\n<h3 class=\"font-headline-lg text-headline-lg text-primary italic uppercase flex items-center gap-md\">\n<span class=\"w-8 h-[2px] bg-gold\"></span> Pizzas\n                    </h3>\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-gutter\">\n<!-- Product Card 3 -->\n<div class=\"bg-surface-card border border-border-warm rounded-xl overflow-hidden card-hover transition-all flex flex-col group\">\n<div class=\"h-48 overflow-hidden\">\n<img class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-105\" data-alt=\"A crispy pepperoni pizza with melting mozzarella cheese and fresh basil leaves on top. The crust is perfectly charred, indicating a wood-fired oven. The lighting is focused and warm, creating high-contrast shadows against the dark surroundings, giving the food a pr